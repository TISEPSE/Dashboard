generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model CryptoFavorite {
  id        String   @id @default(cuid())
  symbol    String   
  name      String
  userId    String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([symbol, userId])
  @@map("crypto_favorites")
}